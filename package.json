    "@tailwindcss/vite": "^4.1.14",
    "@types/morgan": "^1.9.10",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "diff": "^9.0.0",
    "dotenv": "^17.2.3",
