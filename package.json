{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run migrate && tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && esbuild db/migrate.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/migrate.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "tsx db/migrate.ts",
    "bootstrap-admin": "tsx scripts/bootstrap-admin.ts",
    "security-audit": "tsx scripts/security-audit.ts",
    "start": "node dist/migrate.cjs && node dist/server.cjs"
  },
