# STRIPE_SECRET_KEY: Required for Stripe payments
STRIPE_SECRET_KEY=

# STRIPE_WEBHOOK_SECRET: Required for Stripe webhooks
STRIPE_WEBHOOK_SECRET=

# DEMO_MODE: Set to "true" to enable mock bank payments
DEMO_MODE=false

# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_EMAIL: The email address of the user who should be granted admin privileges automatically.
ADMIN_EMAIL=
# ADMIN_ALLOWED_IPS: Comma-separated list of allowed IP addresses for admin access.
ADMIN_ALLOWED_IPS=

# REDIS_URL: Required for distributed token caching and rate limiting. A hard dependency in production.
REDIS_URL=

# DATABASE_URL: Required for Postgres connection
DATABASE_URL=

# GEMINI_MODEL: Optional. Override the default Gemini model
GEMINI_MODEL=

# JWT_SECRET: Required for JWT authentication
JWT_SECRET=

# VITE_GOOGLE_ANALYTICS_ID: Required for Google Analytics
VITE_GOOGLE_ANALYTICS_ID=

# METRICS_TOKEN: Required for accessing /metrics endpoint
METRICS_TOKEN=

# EMAIL_SERVICE: API Key for email provider (e.g., Resend, SendGrid)
EMAIL_API_KEY=
EMAIL_FROM=

# Export Rate Limiting
EXPORT_RATE_LIMIT_WINDOW_MS=
EXPORT_RATE_LIMIT_MAX_REQUESTS=

# Admin Bootstrap CLI Options (Optional)
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME=
ADMIN_BOOTSTRAP_PROMOTE=

# Third-Party PDF Generator Serverless Offloading (Optional)
# If provided, heavy PDF generation is delegated to this microservice API endpoint
PDF_GENERATOR_SERVICE_URL=
PDF_GENERATOR_SERVICE_TOKEN=

# Third-Party Analytics Platform Credentials
# ANALYTICS_PLATFORM: Choose 'google-analytics' (GA4 Reporting API) or 'mixpanel' to track live traffic patterns
ANALYTICS_PLATFORM=
# Google Analytics (GA4) API credentials
GA_PROPERTY_ID=
GA_CLIENT_EMAIL=
GA_PRIVATE_KEY=
# Mixpanel API credentials
MIXPANEL_PROJECT_ID=
MIXPANEL_SERVICE_ACCOUNT_USER=
MIXPANEL_SERVICE_ACCOUNT_PASS=

# Admin Notification webhook (Slack or Discord)
ADMIN_NOTIFICATION_WEBHOOK_URL=





